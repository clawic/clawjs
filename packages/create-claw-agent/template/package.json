    "claw:doctor": "claw --runtime demo doctor --workspace . --json"
  },
  "dependencies": {
    "@clawjs/claw": "^0.1.0"
  },
  "devDependencies": {
    "@clawjs/cli": "^0.1.0",
    "@types/node": "^22.14.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
