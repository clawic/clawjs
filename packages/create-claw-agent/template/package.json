{
  "name": "__APP_NAME__",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/agent.ts report",
    "build": "tsc -p tsconfig.json",
    "agent:report": "tsx src/agent.ts report",
    "agent:session": "tsx src/agent.ts session",
    "agent:reply": "tsx src/agent.ts reply",
    "claw:init": "claw --runtime demo workspace init --workspace . --app-id __APP_SLUG__ --workspace-id __APP_SLUG__ --agent-id __APP_SLUG__",
