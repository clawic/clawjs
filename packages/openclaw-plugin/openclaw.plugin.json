{
  "id": "clawjs",
  "name": "ClawJS",
  "description": "Bridge plugin that exposes structured OpenClaw runtime capabilities to ClawJS.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "observability": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "bufferSize": { "type": "integer", "minimum": 10, "maximum": 2000 },
          "maxSessionMessages": { "type": "integer", "minimum": 1, "maximum": 200 }
        }
      },
      "promptMutation": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean" },
          "prependSystemContext": { "type": "string" }
        }
      },
      "toolControl": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "blockedTools": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "subagentControl": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "denySpawn": { "type": "boolean" }
        }
      }
    }
  },
  "uiHints": {
    "observability.enabled": {
      "label": "Enable Observability"
    },
    "observability.bufferSize": {
      "label": "Event Buffer Size"
    },
    "observability.maxSessionMessages": {
      "label": "Max Session Messages"
    },
    "promptMutation.enabled": {
      "label": "Enable Prompt Mutation",
      "advanced": true
    },
    "promptMutation.prependSystemContext": {
      "label": "Prepended System Context",
      "advanced": true
    },
    "toolControl.blockedTools": {
      "label": "Blocked Tools",
      "advanced": true
    },
    "subagentControl.denySpawn": {
      "label": "Deny Subagent Spawn",
      "advanced": true
    }
  }
}
