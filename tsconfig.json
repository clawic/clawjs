{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "esnext",
      "dom"
    ],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true
  },
  "include": [
    "packages/**/*.ts",
    "examples/**/*.ts"
  ],
  "exclude": [
    "packages/*/template/**/*",
    "packages/*/templates/**/*"
  ]
}
