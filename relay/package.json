{
  "name": "clawjs-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bin/server.ts",
    "dev:ui": "npm --prefix ui run dev",
    "build:ui": "npm --prefix ui run build",
    "build:server": "tsup src/bin/server.ts src/bin/connector.ts --format esm --target node20 --out-dir dist --clean",
    "build": "npm run build:ui && npm run build:server",
    "start": "node dist/server.js",
    "connector": "node dist/connector.js",
    "test": "tsx --test src/**/*.test.ts",
    "test:e2e": "tsx --test tests/e2e/**/*.test.ts"
  },
  "dependencies": {
    "@clawjs/claw": "file:../packages/clawjs-node",
    "@clawjs/workspace": "file:../packages/clawjs-workspace",
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.4.1",
    "fastify": "^5.6.1",
    "jose": "^6.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
