{
  "name": "clawjs-database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bin/server.ts",
    "build": "tsup src/bin/server.ts src/bin/cli.ts --format esm --target node20 --out-dir dist --clean",
    "start": "node dist/server.js",
    "cli": "node dist/cli.js",
    "test": "tsx --test tests/e2e/backend.e2e.test.ts tests/e2e/cli.e2e.test.ts",
    "test:e2e": "playwright test -c playwright.config.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.4.1",
    "fastify": "^5.6.1",
    "jose": "^6.1.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
